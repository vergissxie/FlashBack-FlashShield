# 复制为 .env 后按需填写（Vite 仅暴露 VITE_* 到浏览器，勿在此存放私钥）
# 与 hakerson_demo / 赛方 README 中的部署记录保持一致即可

# 链名称（展示用）
VITE_ORIGIN_CHAIN_LABEL=Sepolia
VITE_DEST_CHAIN_LABEL=Sepolia

# 三类合约地址（源 / 睿应 / 目标）
VITE_ORIGIN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_REACTIVE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_DESTINATION_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# 全流程交易哈希（部署与一次完整演示）
VITE_TX_ORIGIN_DEPLOY=
VITE_TX_REACTIVE_DEPLOY=
VITE_TX_DESTINATION_DEPLOY=
VITE_TX_ORIGIN_TRIGGER=
VITE_TX_REACTIVE_EXECUTION=
VITE_TX_DESTINATION_CALLBACK=

# --- FlashShield（SeeMoon357/FlashShield）链上实时页 /live ---
# 默认已内置 README 部署地址；RPC 默认 PublicNode（若浏览器 CORS 失败可改 Alchemy 等）
# VITE_FS_POSITION_RISK_SIMULATOR=0xc61465d293a4F7EaA11535bB805AF6447b932298
# VITE_FS_PROTECTION_EXECUTOR=0xE5181de9751b82C86ce1f5D5bd2F7B183e8cBd37
# VITE_FS_REACTIVE_PROTECTION=0x2Fb3e3f539B06940Fb37d5258dD409d36B959Bb9
# VITE_FS_ETHEREUM_SEPOLIA_RPC=
# VITE_FS_BASE_SEPOLIA_RPC=
# VITE_FS_REACTIVE_CALLBACK_PROXY=
# VITE_FS_EXPECTED_RVM_ID=

# 营销页「机制演示」视频（默认 public/media/演示视频.mp4，须放在 public 下）
# VITE_MECHANISM_DEMO_VIDEO=/media/other-name.mp4
